// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int            @id @default(autoincrement())
  userName   String         @unique
  email      String         @unique
  password   String
  role       UserRole
  status     Status         @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  assistant  AssistantInfo?
  doctorInfo DoctorInfo?
}

model DoctorInfo {
  id                    Int      @id @default(autoincrement())
  nameEnglish           String?
  nameBangla            String?
  designation           String?
  degree                String?
  specialty             String?
  memberships           String?
  chamberAddress        String?
  hospitalName          String?
  contactNumber         String?
  newPatientVisitingFee Int?
  oldPatientVisitingFee Int?
  email                 String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  users                 User     @relation(fields: [email], references: [email])
}

model SafeMode {
  id        Int      @id @default(autoincrement())
  isSafe    Boolean  @default(false)
  limit     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatientInfo {
  id            Int           @id @default(autoincrement())
  name          String
  age           Int
  sex           Sex
  contactNumber String        @unique
  address       String
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
}

model AssistantInfo {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  fatherName    String
  motherName    String
  dateOfBirth   DateTime
  sex           Sex?
  contactNumber String
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User     @relation(fields: [email], references: [email])
}

model ConnectorInfo {
  id               Int           @id @default(autoincrement())
  name             String
  contactNumber    String
  email            String?
  diagnosticName   String?
  newPatientAmount Int
  oldPatientAmount Int
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appointments     Appointment[]
}

model Appointment {
  id            Int               @id @default(autoincrement())
  patientId     Int
  visitingDate  DateTime?
  patientType   PatientType?
  visitingTime  String?
  connectorId   Int?
  visitingFee   Int?
  discount      Int?
  weight        Float?
  booldPusher   String?
  bloodGroup    String?
  status        AppointmentStatus @default(BOOKED)
  paymentStatus PaymentStatus     @default(UNPAID)
  connectorInfo ConnectorInfo?    @relation(fields: [connectorId], references: [id])
  patientInfo   PatientInfo       @relation(fields: [patientId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum UserRole {
  PATIENT
  DOCTOR
  ASSISTANT
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  BOOKED
  PRESENT
  ABSENT
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIALLY_PAID
}

enum Status {
  ACTIVE
  DELETED
  PUSH
  BLOCK
  PENDING
  CHECKED
  CLOSED
  COMPLETED
}

enum PatientType {
  NEW
  OLD
}
